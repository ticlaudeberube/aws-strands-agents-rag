# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_EMBED_MODEL=nomic-embed-text:v1.5

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_DB_NAME=knowledge_base
LOADER_MILVUS_DB_NAME=knowledge_base
MILVUS_INDEX_TYPE=HNSW              # Index type: HNSW (speed-optimized), IVF_FLAT, FLAT
MILVUS_METRIC_TYPE=COSINE           # Similarity metric: COSINE, L2, IP

# Milvus Index Tuning Parameters (Phase 3A)
# HNSW Parameters (for high-speed approximate search)
MILVUS_HNSW_M=30                    # Maximum connections per element (16-64 typical)
MILVUS_HNSW_EF_CONSTRUCTION=200     # Construction quality (>M, typically 2x-4x M)
# IVF_FLAT Parameters (for large-scale databases)
MILVUS_IVF_NLIST=128                # Number of clusters (typical: 128-1024)
# Search Parameters
MILVUS_SEARCH_EF=64                 # HNSW search beam size (speed vs accuracy, >top_k)

# Collection Names
OLLAMA_COLLECTION_NAME=milvus_rag_collection
RESPONSE_CACHE_COLLECTION_NAME=response_cache     # Collection for cached Q&A pairs (phase 3C)

# Performance Settings
# Run benchmark/ollama-threads-check.py to get optimal thread number
OLLAMA_NUM_THREADS=6
TOKENIZERS_PARALLELISM=false
PYTORCH_MPS_HIGH_WATERMARK_RATIO=0.0

# Embedding and chunk processing
MAX_CHUNK_LENGTH=400
EMBEDDING_DIM=768
RESPONSE_CACHE_EMBEDDING_DIM=768  # Must match ollama_embed_model dimension (nomic-embed-text:v1.5 = 768)

# Application settings
BATCH_SIZE=10
LOG_LEVEL=INFO

# API Server Configuration
API_PORT=8000

# Cache Configuration
# Enable/disable response cache warmup on startup (pre-loads Q&A pairs from data/responses.json)
# Set to false to skip cache warmup in development/testing
ENABLE_CACHE_WARMUP=true
RESPONSE_CACHE_THRESHOLD=0.99      # Semantic cache distance threshold for Milvus COSINE metric (0.92 = 92% similarity match)
RESPONSE_CACHE_STATS_LIMIT=10000   # Maximum number of cached responses to retrieve for statistics (higher = more expensive queries)

# Retrieval Tuning Parameters (Phase 3B)
DEFAULT_TOP_K=10                        # Default number of context chunks for retrieval (typical: 5-15)
SEARCH_COMPARISON_TOP_K=2               # Top-k for product comparison searches (optimized for speed)
EMBEDDING_CACHE_TTL=3600                # Embedding cache time-to-live in seconds (3600 = 1 hour)

# Web Search Configuration
WEB_SEARCH_TIMEOUT=10                  # Timeout for web search requests in seconds
ENABLE_WEB_SEARCH_SUPPLEMENT=false     # Add web search results as supplementary sources to KB results (default: OFF)
# Note: Old strands_rag_agent.py had web search always ON.
# New graph agent uses feature flag for safety - set to true to enable web search.
# When enabled, web search results appear as supplementary sources alongside KB sources in the UI.
WEB_SEARCH_FALLBACK_THRESHOLD=0.15     # KB relevance threshold (0-1) to trigger web search fallback (default: 0.15 = 15%)
# If average KB relevance is below this threshold, web search results are automatically added
# Set to 0.0 to always use web search, 1.0 to never use web search fallback
# 0.15 is restrictive - only fallbacks when KB truly has no good content (was 0.5)

# Empty-Answer Web Search Triggering
# Questions with empty answers in data/responses.json automatically trigger web search
# Example in responses.json:
#   {"question": "What is the latest vector database news?", "answer": "", "sources": []}
# When cache hits this entry, it detects the empty answer and triggers web search for fresh results
# This is useful for news/trends/updates type questions that need current information
TAVILY_API_KEY=                        # Get free API key from https://tavily.com (leave empty to disable web search)

# HTTP Configuration
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/111.0.0.0 Safari/537.36

# AWS Configuration (optional, for agent reasoning with Bedrock)
AWS_REGION=us-west-1
# Uncomment and set if using AWS services
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# Backend Input Validation (API Server)
MIN_MESSAGE_LENGTH=2                   # Minimum message length (backend validation)
MAX_MESSAGE_LENGTH=200               # Maximum message length (backend DoS protection)
ENABLE_HTML_SANITIZATION=true        # Enable HTML sanitization using bleach library
