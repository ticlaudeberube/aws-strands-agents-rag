# API Server Configuration
REACT_APP_API_PORT=8000
REACT_APP_API_HOST=localhost

# Frontend Input Validation (React UI)
REACT_APP_MIN_MESSAGE_LENGTH=2        # Minimum message length (immediate user feedback)
REACT_APP_MAX_MESSAGE_LENGTH=1000     # Maximum message length (reasonable for most questions)
# Note: HTML sanitization is always enabled in frontend (DOMPurify) - no toggle needed for security
