{
  "name": "milvus-rag-chatbot",
  "version": "1.0.0",
  "description": "React chatbot for Milvus RAG with streaming responses",
  "private": true,
  "dependencies": {
  "@types/dompurify": "^3.0.5",
  "dompurify": "^3.4.0",
  "react": "^18.2.0",
  "react-dom": "^18.2.0",
  "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^16.18.0",
    "html-webpack-plugin": "^5.5.0",
    "typescript": "^4.9.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:watch": "playwright test --watch",
    "test:e2e:basic": "playwright test e2e/chatbot-basic.spec.ts",
    "test:e2e:cache": "playwright test e2e/chatbot-cache.spec.ts",
    "test:e2e:mobile": "playwright test --project=mobile-chrome --project=mobile-safari",
    "test:e2e:performance": "playwright test --project=performance",
    "test:e2e:sources": "playwright test e2e/chatbot-sources.spec.ts",
    "test:e2e:search": "playwright test e2e/chatbot-search.spec.ts",
    "test:e2e:status": "playwright test e2e/chatbot-status.spec.ts",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
