# Multi-stage build for React chatbot production deployment
# Stage 1: Build React application
FROM node:18-alpine AS builder

WORKDIR /app

# Copy package files
COPY chatbots/react-chatbot/package*.json ./

# Install dependencies
RUN npm ci

# Copy source code
COPY chatbots/react-chatbot/src ./src
COPY chatbots/react-chatbot/public ./public
COPY chatbots/react-chatbot/.env ./

# Build React app
RUN npm run build

# Stage 2: Production - serve with Nginx
FROM nginx:alpine

# Set working directory
WORKDIR /usr/share/nginx/html

# Copy nginx configuration
COPY docker/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built React app from builder stage
COPY --from=builder /app/build .

# Expose port
EXPOSE 3000

# Health check - verify Nginx is serving content
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
  CMD wget --no-verbose --tries=1 --spider http://localhost:3000 || exit 1

# Start Nginx
CMD ["nginx", "-g", "daemon off;"]
